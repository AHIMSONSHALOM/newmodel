@model ProductHub_MVC.Models.Product

@{
    ViewData["Title"] = (Model == null || Model.ProductId == 0) ? "Add Catalog Product" : "Modify Product Data";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header @((Model == null || Model.ProductId == 0) ? "bg-success" : "bg-primary") text-white py-3">
                    <h4 class="card-title mb-0"><i class="bi bi-file-earmark-text-fill me-2"></i>@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AddProduct" method="post">
                        <input type="hidden" asp-for="ProductId" />

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Product Name</label>
                            <input asp-for="ProductName" class="form-control" placeholder="Enter high-performance description name" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Brand Manufacturer</label>
                            <input asp-for="Brand" class="form-control" placeholder="e.g. Apple, Sony, Logitech" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold">Quantity Level</label>
                                <input asp-for="Quantity" class="form-control" placeholder="e.g. 45 Units" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold">Price Point (Rs.)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Product Rating (0.0 - 5.0 Stars)</label>
                            <input asp-for="ProductRating" type="number" step="0.1" min="0" max="5" class="form-control" placeholder="4.5" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Detailed Descriptive Overview</label>
                            <textarea asp-for="ProductDescription" class="form-control" rows="4" placeholder="Append technical feature details..."></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn @((Model == null || Model.ProductId == 0) ? "btn-success" : "btn-primary") px-4">
                                Save Catalog Entry
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>