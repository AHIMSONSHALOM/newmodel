@model IEnumerable<ProductHub_MVC.Models.Product>
@{
    ViewData["Title"] = "Compare Products";
}

@functions {
    public string GetStarRating(double rating) {
        int rounded = (int)Math.Round(rating);
        string stars = "";
        for (int i = 1; i <= 5; i++) {
            if (i <= rounded) stars += "★";
            else stars += "☆";
        }
        return stars;
    }
}

<div class="container-fluid mt-1 saas-grid-gap">
    <!-- Title & Navigation Bar -->
    <div class="saas-card mb-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title mb-1">Product Comparison</h1>
            <p class="text-secondary m-0" style="font-size: 0.9rem;">Side-by-side parameters comparison for @Model.Count() selected items.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-saas-primary" data-bs-toggle="modal" data-bs-target="#dispatchCompareEmailModal">
                <i class="fa-solid fa-envelope me-1"></i> Email Comparison
            </button>
            <a asp-action="Index" class="btn btn-saas-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Specifications Table Matrix -->
    <div class="saas-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="saas-table mb-0 text-center">
                <thead>
                    <tr>
                        <th class="text-start p-3 fw-bold align-middle" style="width: 220px; min-width: 180px; font-size: 14px; color: var(--text-secondary);">Metrics</th>
                        @foreach (var prod in Model)
                        {
                            <th class="p-3 align-middle" style="min-width: 200px; text-align: center;">
                                @{
                                    string brandLower = prod.Brand?.ToLower() ?? "";
                                    string brandBadgeClass = "brand-badge-default";
                                    if (brandLower.Contains("apple")) brandBadgeClass = "brand-badge-apple";
                                    else if (brandLower.Contains("samsung")) brandBadgeClass = "brand-badge-samsung";
                                    else if (brandLower.Contains("google")) brandBadgeClass = "brand-badge-google";
                                }
                                <span class="brand-badge @brandBadgeClass mb-2">@prod.Brand</span>
                                <h4 class="fw-bold text-dark m-0" style="font-size: 1.1rem; font-family: 'Poppins', sans-serif;">@prod.ProductName</h4>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-start fw-bold text-secondary p-3">Price</td>
                        @foreach (var prod in Model)
                        {
                            <td class="text-success fw-bold p-3" style="font-size: 1.15rem;">Rs. @prod.Price.ToString("N2")</td>
                        }
                    </tr>
                    <tr>
                        <td class="text-start fw-bold text-secondary p-3">Star Rating</td>
                        @foreach (var prod in Model)
                        {
                            <td class="p-3 fw-semibold text-dark">
                                <span class="rating-stars">@GetStarRating(prod.ProductRating)</span>
                                <span class="text-secondary ms-1" style="font-size: 0.85rem;">@prod.ProductRating.ToString("0.0")</span>
                            </td>
                        }
                    </tr>
                    <tr>
                        <td class="text-start fw-bold text-secondary p-3">Quantity</td>
                        @foreach (var prod in Model)
                        {
                            <td class="p-3 text-secondary fw-semibold">@prod.Quantity Units</td>
                        }
                    </tr>
                    <tr>
                        <td class="text-start fw-bold text-secondary p-3">Description</td>
                        @foreach (var prod in Model)
                        {
                            <td class="text-start text-muted p-3 align-top" style="font-size: 0.88rem; line-height: 1.5; font-weight: 500;">
                                @prod.ProductDescription
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Compared Mailing Modal -->
<div class="modal fade" id="dispatchCompareEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow" style="border-radius: 12px; overflow: hidden;">
            <form asp-action="EmailZipData" method="post">
                @foreach (var prod in Model)
                {
                    <input type="hidden" name="ids" value="@prod.ProductId" />
                }
                <div class="modal-header bg-success text-white border-0 py-3">
                    <h5 class="modal-title fw-bold m-0"><i class="fa-solid fa-paper-plane me-2"></i>Email Comparison Dataset</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4" style="font-size: 0.9rem;">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Recipient Email Address</label>
                        <input type="email" name="recipientEmail" class="form-control" placeholder="recipient@gmail.com" required />
                        <div class="form-text text-muted mt-2" style="font-size: 0.78rem;">
                            The system will compress these @Model.Count() rows into a ZIP spreadsheet archive.
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-saas-secondary py-2 px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-saas-primary py-2 px-4">Dispatch Mail</button>
                </div>
            </form>
        </div>
    </div>
</div>