@model IEnumerable<ProductHub_MVC.Models.Product>
@{
    ViewData["Title"] = "Product Hub Console";
}

<div class="container-fluid mt-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-semibold" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-semibold" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div class="d-flex gap-2">
            <button class="btn btn-success fw-semibold px-3" data-bs-toggle="modal" data-bs-target="#addRowFormModal">Add Row</button>
            <a asp-action="DownloadTemplate" class="btn btn-success fw-semibold px-3">Download Template</a>
            <button class="btn btn-success fw-semibold px-3" onclick="triggerImportEngine()">Import</button>
            <button class="btn btn-success fw-semibold px-3" onclick="triggerExportPipeline()">Export</button>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success fw-semibold px-4" onclick="processComparisonMatrix()">Compare</button>
            <button class="btn btn-success fw-semibold px-4" data-bs-toggle="modal" data-bs-target="#dispatchEmailModal">Email</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card border shadow-sm">
                <div class="card-header bg-dark text-white p-3 fw-bold text-uppercase" style="font-size:0.85rem;">
                    Control Filters Menu
                </div>
                <div class="card-body p-3">
                    <form asp-action="Index" method="get" id="filterMatrixForm">
                        <div class="border-bottom pb-2 mb-2">
                            <label class="fw-bold text-secondary mb-1" style="font-size:0.85rem;">Brands</label>
                            <input type="text" name="brandFilter" class="form-control form-control-sm" placeholder="Filter Brand..." value="@ViewBag.CurrentBrand" />
                        </div>
                        <div class="border-bottom pb-2 mb-2">
                            <label class="fw-bold text-secondary mb-1" style="font-size:0.85rem;">Price Boundary</label>
                            <div class="d-flex gap-2">
                                <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="Min" value="@ViewBag.MinPrice" />
                                <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="Max" value="@ViewBag.MaxPrice" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold text-secondary mb-1" style="font-size:0.85rem;">Ratings Metric</label>
                            <input type="number" step="0.1" name="minRating" class="form-control form-control-sm" placeholder="e.g. 4.0" value="@ViewBag.MinRating" />
                        </div>
                        <button type="submit" class="btn btn-dark btn-sm w-100 fw-bold py-2">Apply Filters</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="table-responsive bg-white rounded border shadow-sm">
                <table class="table table-hover align-middle mb-0 table-bordered">
                    <thead class="table-light text-secondary" style="font-size: 0.9rem;">
                        <tr>
                            <th class="text-center" style="width: 140px;">Action</th>
                            <th class="text-center" style="width: 40px;"><input type="checkbox" id="masterGridSelectAll" /></th>
                            <th>Product Name</th>
                            <th>Brand</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <form asp-action="DeleteProduct" asp-route-id="@item.ProductId" method="post" onsubmit="return confirm('Confirm entry drop?');">
                                        <button type="submit" class="btn btn-danger btn-sm px-2">Delete</button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" class="grid-row-checkbox" data-id="@item.ProductId" />
                                </td>
                                <td class="fw-bold text-dark">📱 @item.ProductName</td>
                                <td><span class="badge bg-light text-dark border">@item.Brand</span></td>
                                <td>@item.Quantity</td>
                                <td class="text-success fw-bold">Rs. @item.Price.ToString("N2")</td>
                                <td class="fw-semibold text-warning">★ @item.ProductRating.ToString("0.0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="dispatchEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow text-dark">
            <form asp-action="EmailZipData" method="post">
                <input type="hidden" name="brandFilter" value="@ViewBag.CurrentBrand" />
                <input type="hidden" name="minPrice" value="@ViewBag.MinPrice" />
                <input type="hidden" name="maxPrice" value="@ViewBag.MaxPrice" />
                <input type="hidden" name="minRating" value="@ViewBag.MinRating" />
                
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold">ZIP Compressed Document Transmission</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark mb-1">Target Destination Email Address</label>
                        <input type="email" name="recipientEmail" class="form-control form-control-sm" placeholder="e.g., recipient-staff@stjoseph.com" required />
                        <div class="form-text text-muted" style="font-size:0.75rem;">The server will parse catalog items, generate the Excel worksheet file, compress it inside a ZIP container entry, and transmit automatically via background authentication.</div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Abstain</button>
                    <button type="submit" class="btn btn-success btn-sm px-4">Dispatch Mail</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addRowFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content text-dark">
            <form method="post" action="@Url.Action("AddProduct", "Product")">
                <div class="modal-header bg-dark text-white"><h5 class="modal-title fw-bold">Add New Catalog Item</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div class="mb-2"><label class="small fw-semibold">Product Name</label><input type="text" name="ProductName" class="form-control form-control-sm" required /></div>
                    <div class="mb-2"><label class="small fw-semibold">Brand Label</label><input type="text" name="Brand" class="form-control form-control-sm" required /></div>
                    <div class="mb-2"><label class="small fw-semibold">Quantity Volume</label><input type="text" name="Quantity" class="form-control form-control-sm" required /></div>
                    <div class="mb-2"><label class="small fw-semibold">Market Price (Rs.)</label><input type="number" step="0.01" name="Price" class="form-control form-control-sm" required /></div>
                    <div class="mb-2"><label class="small fw-semibold">Catalog Description Log</label><textarea name="ProductDescription" class="form-control form-control-sm" rows="2"></textarea></div>
                    <div class="mb-2"><label class="small fw-semibold">Score Rating (0.0 - 5.0)</label><input type="number" step="0.1" name="ProductRating" class="form-control form-control-sm" max="5" required /></div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-success btn-sm w-100 fw-bold">Commit Row Parameters To MS-SQL Database</button></div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const masterSelector = document.getElementById("masterGridSelectAll");
        const itemRowsCheckboxes = document.querySelectorAll(".grid-row-checkbox");

        if (masterSelector) {
            masterSelector.addEventListener("change", function () {
                itemRowsCheckboxes.forEach(cb => cb.checked = this.checked);
            });
        }
    });

    function triggerExportPipeline() {
        const currentQueryStrings = new URLSearchParams(window.location.search);
        window.location.href = '/Product/ExportData?' + currentQueryStrings.toString();
    }

    function processComparisonMatrix() {
        const targetChecks = document.querySelectorAll(".grid-row-checkbox:checked");
        const tally = targetChecks.length;

        if (tally < 2 || tally > 4) {
            alert("Please select between 2 and 4 products to view side-by-side comparison matrices.");
            return;
        }

        const queryParams = Array.from(targetChecks).map(cb => `ids=${cb.getAttribute("data-id")}`).join("&");
        window.location.href = `/Product/Compare?${queryParams}`;
    }

    function triggerImportEngine() {
        const uploaderInput = document.createElement('input');
        uploaderInput.type = 'file';
        uploaderInput.accept = '.xlsx, .xls';
        
        uploaderInput.onchange = ev => {
            const uploadedFile = ev.target.files[0];
            const dataBundle = new FormData();
            dataBundle.append('alexaExcelFile', uploadedFile);

            fetch('/Product/ImportData', { method: 'POST', body: dataBundle })
            .then(res => {
                if (res.ok) {
                    alert("Spreadsheet parsed! Catalog items updated.");
                    window.location.reload();
                } else {
                    alert("An error occurred while validating the spreadsheet.");
                }
            });
        };
        uploaderInput.click();
    }
</script>