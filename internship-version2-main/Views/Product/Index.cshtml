@model IEnumerable<ProductHub_MVC.Models.Product>
@{
    ViewData["Title"] = "Product Hub Dashboard Platform";
}

<div class="container-fluid mt-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-semibold shadow-sm" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-semibold shadow-sm" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div class="d-flex gap-2">
            <button class="btn btn-success fw-semibold shadow-sm" data-bs-toggle="modal" data-bs-target="#addRowFormModal">Add Row</button>
            <a asp-action="DownloadTemplate" class="btn btn-success fw-semibold shadow-sm">Download Template</a>
            <button class="btn btn-success fw-semibold shadow-sm" onclick="triggerImportEngine()">Import</button>
            <button class="btn btn-success fw-semibold shadow-sm" onclick="triggerExportPipeline()">Export</button>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary fw-semibold px-4 shadow-sm" onclick="processComparisonMatrix()">Compare</button>
            <button class="btn btn-success fw-semibold px-4 shadow-sm" onclick="openSelectedEmailModal()">Email</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border rounded">
                <div class="card-header bg-dark text-white p-3 fw-bold text-uppercase" style="font-size:0.82rem;">
                    Control Filters Menu
                </div>
                <div class="card-body p-3">
                    <form asp-action="Index" method="get" id="filterMatrixForm">
                        <div class="border-bottom pb-2 mb-2">
                            <div class="d-flex justify-content-between align-items-center" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#brandsArea">
                                <span class="fw-bold text-secondary" style="font-size:0.9rem;">➕ Brands</span>
                            </div>
                            <div id="brandsArea" class="collapse show mt-2">
                                <input type="text" id="brandFilterInput" name="brandFilter" class="form-control form-control-sm" value="@ViewBag.CurrentBrand" placeholder="Search product line..." />
                            </div>
                        </div>

                        <div class="border-bottom pb-2 mb-2">
                            <div class="d-flex justify-content-between align-items-center" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#priceArea">
                                <span class="fw-bold text-secondary" style="font-size:0.9rem;">➕ Price Range</span>
                            </div>
                            <div id="priceArea" class="collapse show mt-2">
                                <div class="d-flex gap-2 mb-2">
                                    <input type="number" id="minPriceInput" name="minPrice" class="form-control form-control-sm" placeholder="Min Price" value="@ViewBag.MinPrice" />
                                    <input type="number" id="maxPriceInput" name="maxPrice" class="form-control form-control-sm" placeholder="Max Price" value="@ViewBag.MaxPrice" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#ratingsArea">
                                <span class="fw-bold text-secondary" style="font-size:0.9rem;">➕ Ratings</span>
                            </div>
                            <div id="ratingsArea" class="collapse show mt-2">
                                <div class="form-check mb-1">
                                    <input class="form-check-input rating-radio-trigger" type="radio" name="minRating" value="4.5" id="r45" @(ViewBag.MinRating == 4.5 ? "checked" : "")>
                                    <label class="form-check-label text-secondary" style="font-size:0.85rem;" for="r45">⭐⭐⭐⭐½ & Up</label>
                                </div>
                                <div class="form-check mb-1">
                                    <input class="form-check-input rating-radio-trigger" type="radio" name="minRating" value="4.0" id="r40" @(ViewBag.MinRating == 4.0 ? "checked" : "")>
                                    <label class="form-check-label text-secondary" style="font-size:0.85rem;" for="r40">⭐⭐⭐⭐☆ & Up</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-2">
                            <button type="submit" class="btn btn-dark btn-sm w-100 fw-bold py-2 shadow-sm">Apply Filters</button>
                            <button type="button" onclick="clearAllSearchFilters()" class="btn btn-outline-secondary btn-sm w-100 fw-bold py-2 shadow-sm">Reset Filters</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="table-responsive bg-white rounded border shadow-sm">
                <table class="table table-hover align-middle mb-0 table-bordered">
                    <thead class="table-light">
                        <tr style="font-size:0.9rem;">
                            <th class="text-center" style="width: 50px;">S.No</th>
                            <th class="text-center" style="width: 100px;">Action</th>
                            <th class="text-center" style="width: 40px;"><input type="checkbox" id="masterGridSelectAll" /></th>
                            <th>Product Name</th>
                            <th>Brand</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            // ✅ INITIALIZE INDEX VALUE FOR DYNAMIC ROW TRACKING
                            int rowCounter = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold text-secondary" style="font-size:0.88rem;">@rowCounter</td>
                                <td class="text-center">
                                    <form asp-action="DeleteProduct" asp-route-id="@item.ProductId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm px-2 py-0" style="font-size:0.8rem;">Delete</button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" class="grid-row-checkbox" data-id="@item.ProductId" />
                                </td>
                                <td class="fw-bold text-dark">@item.ProductName</td>
                                <td><span class="badge bg-light text-dark border">@item.Brand</span></td>
                                <td>@item.Quantity</td>
                                <td class="text-success fw-bold">Rs. @item.Price.ToString("N2")</td>
                                <td><span class="text-warning">★</span> @item.ProductRating.ToString("0.0")</td>
                            </tr>
                            
                            {
                                // INCREMENT BY 1 FOR THE NEXT LOOP ITEM ROW ROW OBJECT
                                rowCounter++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="dispatchEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="EmailZipData" method="post" id="dashboardMailingForm">
                <div id="selectedIdsHiddenContainer"></div>
                
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">📦 Selected Inventory Email Service</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="font-size: 0.9rem;">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Recipient Email Address</label>
                        <input type="email" id="destinationMailBoxInput" name="recipientEmail" class="form-control" placeholder="recipient@gmail.com" required />
                        <div class="form-text text-muted" style="font-size: 0.78rem;">The system will extract only your checked table items and wrap them inside the compressed zip report.</div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success btn-sm px-4">Dispatch Mail</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addRowFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="AddProduct" method="post">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">Add Catalog Entry Form</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="font-size:0.9rem;">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Product Name</label>
                        <input type="text" name="ProductName" class="form-control form-control-sm" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Brand Classification</label>
                        <input type="text" name="Brand" class="form-control form-control-sm" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantity Metrics</label>
                        <input type="text" name="Quantity" class="form-control form-control-sm" placeholder="e.g. 50 Units" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Price Value</label>
                        <input type="number" step="0.01" name="Price" class="form-control form-control-sm" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Star Ratings</label>
                        <input type="number" step="0.1" min="0" max="5" name="ProductRating" class="form-control form-control-sm" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description Context Notes</label>
                        <textarea name="ProductDescription" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-success btn-sm px-3">Commit to Database</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script type="text/javascript">
    document.addEventListener("DOMContentLoaded", function () {
        const masterSelector = document.getElementById("masterGridSelectAll");
        const itemRowsCheckboxes = document.querySelectorAll(".grid-row-checkbox");

        if (masterSelector) {
            masterSelector.addEventListener("change", function () {
                itemRowsCheckboxes.forEach(cb => cb.checked = this.checked);
            });
        }
    });

    function openSelectedEmailModal() {
        const targetChecks = document.querySelectorAll(".grid-row-checkbox:checked");
        if (targetChecks.length === 0) {
            alert("Selection Guard Warning:\nPlease select at least one product row checkbox to execute the custom data mailing feature.");
            return;
        }

        const hiddenContainer = document.getElementById("selectedIdsHiddenContainer");
        hiddenContainer.innerHTML = ""; 

        targetChecks.forEach(cb => {
            const inputField = document.createElement("input");
            inputField.type = "hidden";
            inputField.name = "ids";
            inputField.value = cb.getAttribute("data-id");
            hiddenContainer.appendChild(inputField);
        });

        var mailFormModal = new bootstrap.Modal(document.getElementById('dispatchEmailModal'));
        mailFormModal.show();
    }

    function clearAllSearchFilters() {
        document.getElementById("brandFilterInput").value = "";
        document.getElementById("minPriceInput").value = "";
        document.getElementById("maxPriceInput").value = "";
        
        const activeRadios = document.querySelectorAll(".rating-radio-trigger");
        activeRadios.forEach(radio => radio.checked = false);
        
        window.location.href = "/Product/Index";
    }

    function processComparisonMatrix() {
        const targetChecks = document.querySelectorAll(".grid-row-checkbox:checked");
        if (targetChecks.length < 2 || targetChecks.length > 4) {
            alert("Selection Boundary Check Alert:\nPlease choose between 2 and 4 product lines to compare side-by-side.");
            return;
        }
        const queryParams = Array.from(targetChecks).map(cb => "ids=" + cb.getAttribute("data-id")).join("&");
        window.location.href = "/Product/Compare?" + queryParams;
    }

    function triggerExportPipeline() {
        window.location.href = '/Product/ExportData' + window.location.search;
    }

    function triggerImportEngine() {
        const uploaderInput = document.createElement('input');
        uploaderInput.type = 'file';
        uploaderInput.accept = '.xlsx, .xls';
        uploaderInput.onchange = ev => {
            const dataBundle = new FormData();
            dataBundle.append('alexaExcelFile', ev.target.files[0]);
            fetch('/Product/ImportData', { method: 'POST', body: dataBundle }).then(() => window.location.reload());
        };
        uploaderInput.click();
    }
</script>