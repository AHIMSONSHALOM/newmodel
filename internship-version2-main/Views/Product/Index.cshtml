@model IEnumerable<ProductHub_MVC.Models.Product>
@{
    ViewData["Title"] = "PRODUCTHUB CONSOLE";
    int sequentialNumber = 1;
}

<div class="container-fluid mt-1">
    <div class="d-flex justify-content-end align-items-center mb-3 flex-wrap gap-2 bg-white p-2 rounded shadow-sm border">
        <div class="d-flex gap-2">
            @if (ViewBag.CanAddRow == 1)
            {
                <button class="btn btn-success fw-semibold shadow-sm px-3" data-bs-toggle="modal" data-bs-target="#addProductModal">Add Row</button>
            }
            @if (ViewBag.CanDownload == 1)
            {
                <a asp-action="DownloadTemplate" class="btn btn-success fw-semibold shadow-sm px-3">Download Template</a>
            }
            @if (ViewBag.CanImport == 1)
            {
                <button class="btn btn-success fw-semibold shadow-sm px-3" data-bs-toggle="modal" data-bs-target="#importExcelModal">Import</button>
            }
            @if (ViewBag.CanExport == 1)
            {
                <a href="#" onclick="triggerExport()" class="btn btn-success fw-semibold shadow-sm px-3">Export</a>
            }
            @if (ViewBag.CanCompare == 1)
            {
                <button type="button" onclick="triggerComparison()" class="btn btn-primary fw-semibold shadow-sm px-4">Compare</button>
            }
            @if (ViewBag.CanEmail == 1)
            {
                <button type="button" data-bs-toggle="modal" data-bs-target="#dispatchCheckedEmailModal" class="btn btn-success fw-semibold shadow-sm px-4">Email</button>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card shadow-sm border rounded">
                <div class="card-header bg-dark text-white fw-bold text-uppercase p-3" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                    Control Filters Menu
                </div>
                <div class="card-body bg-white p-3">
                    <form id="filterForm" method="get" asp-action="Index">
                        <input type="hidden" name="sortBy" value="@ViewBag.CurrentSort" />
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">+ Brands</label>
                            <input type="text" name="brandFilter" value="@ViewBag.CurrentBrand" class="form-control form-control-sm" placeholder="Search product line..." />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">+ Price Range</label>
                            <div class="d-flex gap-2">
                                <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control form-control-sm" placeholder="Min Price" />
                                <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control form-control-sm" placeholder="Max Price" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">+ Ratings</label>
                            <div class="form-check small mb-1">
                                <input class="form-check-input" type="radio" name="minRating" value="4.5" id="rate45" @(ViewBag.MinRating == 4.5 ? "checked" : "")>
                                <label class="form-check-label text-dark" for="rate45">⭐ 4.5 & Up</label>
                            </div>
                            <div class="form-check small mb-1">
                                <input class="form-check-input" type="radio" name="minRating" value="4.0" id="rate40" @(ViewBag.MinRating == 4.0 ? "checked" : "")>
                                <label class="form-check-label text-dark" for="rate40">⭐ 4.0 & Up</label>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-dark btn-sm w-100 fw-bold py-2 mb-2">Apply Filters</button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 fw-semibold py-2">Reset Filters</a>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm border rounded">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <form id="checkedItemsForm" method="post">
                            <table class="table table-hover align-middle mb-0 text-center">
                                <thead class="table-light text-secondary small fw-bold">
                                    <tr>
                                        <th style="width: 60px;">S.No</th>
                                        <th style="width: 140px;">Action</th>
                                        <th style="width: 40px;"><input type="checkbox" id="selectAllBoxes" class="form-check-input" /></th>
                                        <th class="text-start">Product Name ↕️</th>
                                        <th>Brand</th>
                                        <th>Quantity</th>
                                        <th>Price ↕️</th>
                                        <th>Rating</th>
                                    </tr>
                                </thead>
                                <tbody class="text-dark small">
                                    @foreach (var prod in Model)
                                    {
                                        <tr>
                                            <td class="text-secondary fw-semibold">@(sequentialNumber++)</td>
                                            <td>
                                                <div class="d-flex justify-content-center gap-1">
                                                    <button type="button" class="btn btn-sm btn-outline-primary fw-semibold px-2 py-0" style="font-size: 0.78rem; height: 24px;" onclick="triggerEditModal('@prod.ProductId', '@prod.ProductName', '@prod.Brand', '@prod.Quantity', '@prod.Price', '@prod.ProductRating', '@prod.ProductDescription')">Edit</button>
                                                    <button type="button" class="btn btn-sm btn-outline-danger fw-semibold px-2 py-0" style="font-size: 0.78rem; height: 24px;" onclick="triggerDeletePost('@prod.ProductId')">Delete</button>
                                                </div>
                                            </td>
                                            <td><input type="checkbox" name="ids" value="@prod.ProductId" class="form-check-input row-item-checkbox" /></td>
                                            <td class="text-start fw-semibold text-dark">@prod.ProductName</td>
                                            <td><span class="badge bg-light text-dark border px-2 py-1">@prod.Brand</span></td>
                                            <td class="text-secondary">@prod.Quantity</td>
                                            <td class="text-success fw-bold">Rs. @prod.Price.ToString("N2")</td>
                                            <td class="fw-semibold"><span class="text-warning">★</span> @prod.ProductRating.ToString("0.0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="AddProduct" method="post">
                <div class="modal-header bg-dark text-white"><h5 class="modal-title fw-bold">➕ Create New Row</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body small">
                    <div class="mb-3"><label class="form-label fw-bold">Product Name</label><input type="text" name="ProductName" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Brand</label><input type="text" name="Brand" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Quantity</label><input type="text" name="Quantity" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Price</label><input type="number" step="0.01" name="Price" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Rating</label><input type="number" step="0.1" name="ProductRating" class="form-control form-control-sm" min="0" max="5" required /></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-success btn-sm px-4">Save Row</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="EditProduct" method="post">
                <input type="hidden" name="ProductId" id="edit_ProductId" />
                <div class="modal-header bg-primary text-white"><h5 class="modal-title fw-bold">📝 Edit Parameters</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body small">
                    <div class="mb-3"><label class="form-label fw-bold">Product Name</label><input type="text" name="ProductName" id="edit_ProductName" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Brand</label><input type="text" name="Brand" id="edit_Brand" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Quantity</label><input type="text" name="Quantity" id="edit_Quantity" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Price</label><input type="number" step="0.01" name="Price" id="edit_Price" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Rating</label><input type="number" step="0.1" name="ProductRating" id="edit_Rating" class="form-control form-control-sm" min="0" max="5" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Description</label><textarea name="ProductDescription" id="edit_Description" class="form-control form-control-sm" rows="3"></textarea></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary btn-sm px-4">Update</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="importExcelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content border-0 shadow"><form asp-action="ImportData" method="post" enctype="multipart/form-data"><div class="modal-header bg-dark text-white"><h5 class="modal-title fw-bold">📥 Import Excel Sheet</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body small"><div class="mb-3"><label class="form-label fw-bold">Select File</label><input type="file" name="alexaExcelFile" class="form-control form-control-sm" accept=".xlsx" required /></div></div><div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-success btn-sm px-4">Parse</button></div></form></div></div>
</div>

<div class="modal fade" id="dispatchCheckedEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content border-0 shadow"><div class="modal-header bg-success text-white"><h5 class="modal-title fw-bold">📧 Dispatch Packet</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body small"><div class="mb-3"><label class="form-label fw-bold">Recipient Mail Address</label><input type="email" id="modalEmailInputBox" class="form-control form-control-sm" placeholder="recipient@gmail.com" required /></div></div><div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="button" onclick="executeCheckedEmailPipeline()" class="btn btn-success btn-sm px-4">Transmit</button></div></div></div>
</div>

<script>
    document.getElementById('selectAllBoxes').addEventListener('change', function() {
        let targets = document.querySelectorAll('.row-item-checkbox');
        targets.forEach(box => box.checked = this.checked);
    });
    function triggerComparison() {
        let checkboxes = document.querySelectorAll('.row-item-checkbox:checked');
        if (checkboxes.length < 2 || checkboxes.length > 4) { alert("Please check between 2 and 4 rows to Compare."); return; }
        let urlParams = Array.from(checkboxes).map(box => "ids=" + box.value).join("&");
        window.location.href = "/Product/Compare?" + urlParams;
    }
    function triggerExport() {
        let form = document.getElementById('filterForm');
        let brand = form.querySelector('[name="brandFilter"]')?.value || "";
        let minP = form.querySelector('[name="minPrice"]').value;
        let maxP = form.querySelector('[name="maxPrice"]').value;
        let rating = form.querySelector('[name="minRating"]:checked')?.value || "";
        window.location.href = `/Product/ExportData?brandFilter=${encodeURIComponent(brand)}&minPrice=${minP}&maxPrice=${maxP}&minRating=${rating}`;
    }
    function executeCheckedEmailPipeline() {
        let boxes = document.querySelectorAll('.row-item-checkbox:checked');
        let mailAddress = document.getElementById('modalEmailInputBox').value.trim();
        if (!mailAddress || boxes.length === 0) { alert("Selection and Email entry required."); return; }
        let form = document.getElementById('checkedItemsForm');
        form.action = `/Product/EmailZipData?recipientEmail=${encodeURIComponent(mailAddress)}`;
        form.submit();
    }
    function triggerDeletePost(id) {
        if(confirm("Delete this record component?")) {
            let f = document.createElement('form'); f.method = 'POST'; f.action = '/Product/DeleteProduct/' + id;
            document.body.appendChild(f); f.submit();
        }
    }
    function triggerEditModal(id, name, brand, qty, price, rating, desc) {
        document.getElementById('edit_ProductId').value = id; document.getElementById('edit_ProductName').value = name;
        document.getElementById('edit_Brand').value = brand; document.getElementById('edit_Quantity').value = qty;
        document.getElementById('edit_Price').value = price; document.getElementById('edit_Rating').value = rating;
        document.getElementById('edit_Description').value = desc;
        new bootstrap.Modal(document.getElementById('editProductModal')).show();
    }
</script>