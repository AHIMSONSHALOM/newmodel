@model IEnumerable<Dictionary<string, object>>
@{
    ViewData["Title"] = "User Control Panel";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-3 rounded shadow-sm border">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-users-gear text-success me-2"></i>User Access Management Matrix</h3>
            <p class="text-muted m-0 small">Enforce structural button visibility permissions and column locks instantly in real-time</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary fw-semibold shadow-sm px-3" data-bs-toggle="modal" data-bs-target="#addNewUserModal">
                <i class="fa-solid fa-user-plus me-1"></i> Add New User Account
            </button>
            <a asp-action="Index" class="btn btn-dark fw-semibold shadow-sm px-3">Dashboard</a>
            <a asp-action="Logout" asp-controller="Account" class="btn btn-danger fw-semibold shadow-sm px-3">Logout</a>
        </div>
    </div>

    <div class="card shadow-sm border rounded">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0 text-center">
                    <thead class="table-light text-secondary small fw-bold">
                        <tr>
                            <th>User ID</th>
                            <th>Username Profile</th>
                            <th>Registered Mobile</th>
                            <th>Password Key</th>
                            <th>Actions</th>
                            <th class="text-start p-3" style="width: 600px;">Features Access Switches Control Frame</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark small">
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="text-secondary fw-semibold">@u["Id"]</td>
                                <td class="fw-bold text-dark">👤 @u["Name"]</td>
                                <td class="fw-semibold text-secondary">📱 @u["Mobile"]</td>
                                <td><code class="bg-light border px-2 py-1 text-danger rounded fw-bold">@u["Password"]</code></td>
                                <td>
                                    @if (Convert.ToInt32(u["IsAdmin"]) == 1) {
                                        <span class="badge bg-danger">SYSTEM ROOT ADMIN</span>
                                    } else {
                                        <div class="d-flex justify-content-center gap-1">
                                            <button type="button" class="btn btn-xs btn-outline-primary fw-bold" onclick="openPassChangeModal('@u["Id"]', '@u["Name"]')">Pass</button>
                                            <form asp-action="AdministrativeDeleteUser" method="post" onsubmit="return confirm('Prune this account record completely from active registers?');">
                                                <input type="hidden" name="userId" value="@u["Id"]" />
                                                <button type="submit" class="btn btn-xs btn-outline-danger fw-bold">Delete</button>
                                            </form>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (Convert.ToInt32(u["IsAdmin"]) == 1) {
                                        <div class="text-muted small py-2"><i class="fa-solid fa-shield-halved me-1"></i> Root Administrator capabilities are structurally absolute.</div>
                                    } else {
                                        <form asp-action="SaveUserConfig" method="post" class="p-3 bg-light border rounded">
                                            <input type="hidden" name="userId" value="@u["Id"]" />
                                            
                                            <div class="row text-start mb-2">
                                                <div class="col-md-6 mb-2">
                                                    <div class="fw-bold text-primary mb-1 border-bottom pb-1" style="font-size:0.75rem; text-transform:uppercase;">Top Utility Buttons</div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["AddRow"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="addRow" value="@u["AddRow"]" />
                                                        <label class="form-check-label text-muted small">Add Row Button</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Download"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="download" value="@u["Download"]" />
                                                        <label class="form-check-label text-muted small">Download Template</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Import"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="import" value="@u["Import"]" />
                                                        <label class="form-check-label text-muted small">Import Excel</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Export"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="export" value="@u["Export"]" />
                                                        <label class="form-check-label text-muted small">Export Data</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Compare"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="compare" value="@u["Compare"]" />
                                                        <label class="form-check-label text-muted small">Compare Actions</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Email"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="email" value="@u["Email"]" />
                                                        <label class="form-check-label text-muted small">Email Services</label>
                                                    </div>
                                                </div>
                                                
                                                <div class="col-md-6 mb-2">
                                                    <div class="fw-bold text-success mb-1 border-bottom pb-1" style="font-size:0.75rem; text-transform:uppercase;">Columns & Row Actions</div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeeBrand"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="seeBrand" value="@u["SeeBrand"]" />
                                                        <label class="form-check-label text-muted small">Show Brand Column</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeeQty"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="seeQty" value="@u["SeeQty"]" />
                                                        <label class="form-check-label text-muted small">Show Quantity Column</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeePrice"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="seePrice" value="@u["SeePrice"]" />
                                                        <label class="form-check-label text-muted small">Show Price Column</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeeRating"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="seeRating" value="@u["SeeRating"]" />
                                                        <label class="form-check-label text-muted small">Show Rating Column</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1 border-top pt-1 mt-2">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["UseEdit"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="useEdit" value="@u["UseEdit"]" />
                                                        <label class="form-check-label text-muted small fw-bold text-primary">Enable Inline Edit</label>
                                                    </div>
                                                    <div class="form-check form-switch ps-5 my-1">
                                                        <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["UseDelete"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                        <input type="hidden" name="useDelete" value="@u["UseDelete"]" />
                                                        <label class="form-check-label text-muted small fw-bold text-danger">Enable Inline Delete</label>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <button type="submit" class="btn btn-sm btn-success w-100 fw-bold mt-2"><i class="fa-solid fa-square-check me-1"></i> Synchronize Role Constraints</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addNewUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="AdministrativeAddUser" method="post">
                <div class="modal-header bg-dark text-white"><h5 class="modal-title fw-bold">👤 Append New Account Mapping</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body small">
                    <div class="mb-3"><label class="form-label fw-bold">Account Username Profile</label><input type="text" name="username" class="form-control form-control-sm" placeholder="e.g. user3" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Mobile Registration Number</label><input type="text" name="mobile" class="form-control form-control-sm" placeholder="e.g. 9876543213" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Password Security Key</label><input type="text" name="password" class="form-control form-control-sm" placeholder="Set initial secret key..." required /></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary btn-sm px-4">Register User</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="adminPassChangeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="AdministrativeChangeUserPassword" method="post">
                <input type="hidden" name="userId" id="tgt_userId" />
                <div class="modal-header bg-primary text-white"><h5 class="modal-title fw-bold">🔑 Overwrite User Password</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body small">
                    <div class="mb-3"><label class="form-label fw-bold">Target Account Profile</label><input type="text" id="tgt_username" class="form-control form-control-sm bg-light" readonly /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Input New Password Security Key</label><input type="text" name="nextPassword" class="form-control form-control-sm" placeholder="Type next alpha-numeric key string..." required /></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary btn-sm px-4">Overwrite Key</button></div>
            </form>
        </div>
    </div>
</div>

<script>
    function openPassChangeModal(id, name) {
        document.getElementById('tgt_userId').value = id;
        document.getElementById('tgt_username').value = "👤 " + name;
        new bootstrap.Modal(document.getElementById('adminPassChangeModal')).show();
    }
</script>