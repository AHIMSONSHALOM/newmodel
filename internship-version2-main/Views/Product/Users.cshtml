@model IEnumerable<Dictionary<string, object>>
@{
    ViewData["Title"] = "User Control Panel";
    // Read the dictionary parameter containing live database product counts
    var brandCountsDictionary = ViewBag.AvailableBrandsWithCounts as Dictionary<string, int> ?? new Dictionary<string, int> { { "ALL", 0 } };
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-3 rounded shadow-sm border">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-users-gear text-success me-2"></i>User Access Management Matrix</h3>
            <p class="text-muted m-0 small">Enforce structural button visibility permissions and column locks instantly in real-time</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary fw-semibold shadow-sm px-3" data-bs-toggle="modal" data-bs-target="#addNewUserModal">
                <i class="fa-solid fa-user-plus me-1"></i> Add New User Account
            </button>
            <a asp-action="History" class="btn btn-warning fw-semibold shadow-sm px-3"><i class="fa-solid fa-history me-1"></i> View Global Logs</a>
            <a asp-action="Index" class="btn btn-dark fw-semibold shadow-sm px-3">Dashboard</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-3 small" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border rounded">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0 text-center">
                    <thead class="table-light text-secondary small fw-bold">
                        <tr>
                            <th>User ID</th>
                            <th>Username Profile</th>
                            <th>Registered Mobile</th>
                            <th>Email Address</th>
                            <th>Password Key</th>
                            <th>Actions Control</th>
                            <th class="text-start p-3" style="width: 580px;">Features Access Switches Control Frame</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark small">
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="text-secondary fw-semibold">@u["Id"]</td>
                                <td class="fw-bold text-dark">👤 @u["Name"]</td>
                                <td class="fw-semibold text-secondary">📱 @u["Mobile"]</td>
                                <td class="fw-semibold text-secondary">
                                    @if (!string.IsNullOrWhiteSpace(u["EmailAddress"]?.ToString())) {
                                        <span>✉️ @u["EmailAddress"]</span>
                                    } else {
                                        <span class="text-muted small"><em>Not Set</em></span>
                                    }
                                </td>
                                <td><code class="bg-light border px-2 py-1 text-danger rounded fw-bold">@u["Password"]</code></td>

                                <td>
                                    @if (Convert.ToInt32(u["IsAdmin"]) == 1) {
                                        <span class="badge bg-danger">SYSTEM ROOT ADMIN</span>
                                    } else {
                                        <div class="d-flex flex-column gap-1 align-items-center">
                                            <div class="d-flex gap-1 justify-content-center">
                                                <button type="button" class="btn btn-xs btn-outline-primary fw-bold" onclick="openPassChangeModal('@u["Id"]', '@u["Name"]')">Pass</button>
                                                <form asp-action="AdministrativeDeleteUser" method="post" onsubmit="return confirm('Prune account record completely?');">
                                                    <input type="hidden" name="userId" value="@u["Id"]" />
                                                    <input type="hidden" name="targetName" value="@u["Name"]" />
                                                    <button type="submit" class="btn btn-xs btn-outline-danger fw-bold">Delete</button>
                                                </form>
                                            </div>
                                            <a asp-action="History" asp-route-targetUser="@u["Name"]" class="btn btn-xs btn-success text-white fw-bold w-100 mt-1" style="font-size:0.7rem; padding:2px 4px;">
                                                <i class="fa-solid fa-clock-history me-1"></i> View History
                                            </a>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (Convert.ToInt32(u["IsAdmin"]) == 1) {
                                        <div class="text-muted small py-2"><i class="fa-solid fa-shield-halved me-1"></i> Root Administrator capabilities are structurally absolute.</div>
                                    } else {
                                        <form asp-action="SaveUserConfig" method="post" class="p-3 bg-light border rounded">
                                            <input type="hidden" name="userId" value="@u["Id"]" />
                                            <input type="hidden" name="userNameParam" value="@u["Name"]" />
                                            
                                            <!-- User Email Input Field -->
                                            <div class="mb-3 bg-white p-2 border rounded shadow-sm text-start">
                                                <label class="form-label fw-bold text-dark mb-1 small" style="font-size:0.75rem;"><i class="fa-solid fa-envelope text-primary me-1"></i>User Email (Admin Editable)</label>
                                                <input type="email" name="userEmail" class="form-control form-control-sm" value="@u["EmailAddress"]" placeholder="user@gmail.com" />
                                            </div>

                                            <div class="row text-start mb-2">
                                                <div class="col-md-5 mb-2">
                                                    <div class="fw-bold text-primary mb-1 border-bottom pb-1" style="font-size:0.75rem; text-transform:uppercase;">Top Utility Buttons</div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["AddRow"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="addRow" value="@u["AddRow"]" /><label class="form-check-label text-muted small">Add Row Button</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Download"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="download" value="@u["Download"]" /><label class="form-check-label text-muted small">Download Template</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Import"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="import" value="@u["Import"]" /><label class="form-check-label text-muted small">Import Excel</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Export"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="export" value="@u["Export"]" /><label class="form-check-label text-muted small">Export Data</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Compare"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="compare" value="@u["Compare"]" /><label class="form-check-label text-muted small">Compare Actions</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["Email"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="email" value="@u["Email"]" /><label class="form-check-label text-muted small">Email Services</label></div>
                                                </div>
                                                
                                                <div class="col-md-7 mb-2">
                                                    <div class="fw-bold text-success mb-1 border-bottom pb-1" style="font-size:0.75rem; text-transform:uppercase;">Columns & Row Actions</div>
                                                    
                                                    <div class="d-flex align-items-center justify-content-between my-1 bg-white p-1 rounded border">
                                                        <div class="form-check form-switch ps-5">
                                                            <input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeeBrand"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" />
                                                            <input type="hidden" name="seeBrand" value="@u["SeeBrand"]" />
                                                            <label class="form-check-label text-muted small fw-bold">Show Brand</label>
                                                        </div>
                                                        <div class="pe-1">
                                                            <input type="hidden" name="restrictedBrand" id="restrictedBrand_@u["Id"]" value="@u["RestrictedBrand"]" />
                                                            <div class="dropdown">
                                                                <button class="btn btn-sm btn-outline-success dropdown-toggle fw-bold py-0" type="button" id="brandBtn_@u["Id"]" data-bs-toggle="dropdown" aria-expanded="false" style="font-size:0.75rem; min-width:165px; height:26px; text-align:left;">
                                                                    @{
                                                                        string restrictedStr = u["RestrictedBrand"].ToString();
                                                                        string buttonText = "ALL";
                                                                        if (restrictedStr != "ALL" && !string.IsNullOrEmpty(restrictedStr)) {
                                                                            var parts = restrictedStr.Split(',');
                                                                            if (parts.Length == 1) {
                                                                                int count = brandCountsDictionary.ContainsKey(parts[0]) ? brandCountsDictionary[parts[0]] : 0;
                                                                                buttonText = $"{parts[0]} ({count} Items)";
                                                                            } else {
                                                                                int totalItems = 0;
                                                                                foreach (var part in parts) {
                                                                                    if (brandCountsDictionary.ContainsKey(part)) totalItems += brandCountsDictionary[part];
                                                                                }
                                                                                buttonText = $"{parts.Length} Brands ({totalItems} Items)";
                                                                            }
                                                                        } else {
                                                                            int count = brandCountsDictionary.ContainsKey("ALL") ? brandCountsDictionary["ALL"] : 0;
                                                                            buttonText = $"ALL ({count} Products)";
                                                                        }
                                                                    }
                                                                    @buttonText
                                                                </button>
                                                                <div class="dropdown-menu p-3 shadow" aria-labelledby="brandBtn_@u["Id"]" style="min-width: 200px; max-height: 250px; overflow-y: auto;">
                                                                    <div class="form-check border-bottom pb-2 mb-2">
                                                                        <input class="form-check-input brand-chk-all" type="checkbox" id="chkAll_@u["Id"]" value="ALL" @(u["RestrictedBrand"].ToString() == "ALL" ? "checked" : "") onchange="onBrandAllChanged(@u["Id"])" />
                                                                        <label class="form-check-label small fw-bold text-success" for="chkAll_@u["Id"]">
                                                                            🎯 ALL (@(brandCountsDictionary.ContainsKey("ALL") ? brandCountsDictionary["ALL"] : 0) Products)
                                                                        </label>
                                                                    </div>
                                                                    @foreach (var kvp in brandCountsDictionary)
                                                                    {
                                                                        if (kvp.Key == "ALL") continue;
                                                                        bool isChecked = u["RestrictedBrand"].ToString().Split(',').Contains(kvp.Key);
                                                                        <div class="form-check my-1">
                                                                            <input class="form-check-input brand-chk-item brand-chk-@u["Id"]" type="checkbox" id="chk_@u["Id"]_@kvp.Key" value="@kvp.Key" data-count="@kvp.Value" @(isChecked ? "checked" : "") onchange="onBrandItemChanged(@u["Id"])" />
                                                                            <label class="form-check-label small" for="chk_@u["Id"]_@kvp.Key">
                                                                                @kvp.Key (@kvp.Value Items)
                                                                            </label>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeeQty"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="seeQty" value="@u["SeeQty"]" /><label class="form-check-label text-muted small">Show Quantity Column</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeePrice"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="seePrice" value="@u["SeePrice"]" /><label class="form-check-label text-muted small">Show Price Column</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["SeeRating"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="seeRating" value="@u["SeeRating"]" /><label class="form-check-label text-muted small">Show Rating Column</label></div>
                                                    <div class="form-check form-switch ps-5 my-1 border-top pt-1 mt-2"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["UseEdit"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="useEdit" value="@u["UseEdit"]" /><label class="form-check-label text-muted small fw-bold text-primary">Enable Inline Edit</label></div>
                                                    <div class="form-check form-switch ps-5 my-1"><input type="checkbox" class="form-check-input" value="1" @(Convert.ToInt32(u["UseDelete"]) == 1 ? "checked" : "") onchange="this.nextElementSibling.value = this.checked ? '1' : '0';" /><input type="hidden" name="useDelete" value="@u["UseDelete"]" /><label class="form-check-label text-muted small fw-bold text-danger">Enable Inline Delete</label></div>
                                                </div>
                                            </div>
                                            
                                            <button type="submit" class="btn btn-sm btn-success w-100 fw-bold mt-2"><i class="fa-solid fa-square-check me-1"></i> Synchronize Role Constraints</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addNewUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="AdministrativeAddUser" method="post">
                <div class="modal-header bg-dark text-white"><h5 class="modal-title fw-bold">👤 Append New Account Mapping</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body small">
                    <div class="mb-3"><label class="form-label fw-bold">Account Username Profile</label><input type="text" name="username" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Mobile Registration Number</label><input type="text" name="mobile" class="form-control form-control-sm" required /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Email Address</label><input type="email" name="email" class="form-control form-control-sm" required placeholder="user@gmail.com" /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Password Security Key</label><input type="text" name="password" class="form-control form-control-sm" required /></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary btn-sm px-4">Register User</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="adminPassChangeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form asp-action="AdministrativeChangeUserPassword" method="post">
                <input type="hidden" name="userId" id="tgt_userId" />
                <input type="hidden" name="targetName" id="tgt_username_hidden" />
                <div class="modal-header bg-primary text-white"><h5 class="modal-title fw-bold">🔑 Overwrite User Password</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body small">
                    <div class="mb-3"><label class="form-label fw-bold">Target Account Profile</label><input type="text" id="tgt_username" class="form-control form-control-sm bg-light" readonly /></div>
                    <div class="mb-3"><label class="form-label fw-bold">Input New Password Security Key</label><input type="text" name="nextPassword" class="form-control form-control-sm" required /></div>
                </div>
                <div class="modal-footer bg-light"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary btn-sm px-4">Overwrite Key</button></div>
            </form>
        </div>
    </div>
</div>

<script>
    function openPassChangeModal(id, name) {
        document.getElementById('tgt_userId').value = id;
        document.getElementById('tgt_username_hidden').value = name;
        document.getElementById('tgt_username').value = "👤 " + name;
        new bootstrap.Modal(document.getElementById('adminPassChangeModal')).show();
    }

    function onBrandAllChanged(userId) {
        var chkAll = document.getElementById("chkAll_" + userId);
        var itemCheckboxes = document.querySelectorAll(".brand-chk-" + userId);
        
        if (chkAll.checked) {
            // Uncheck all item checkboxes
            itemCheckboxes.forEach(function(chk) {
                chk.checked = false;
            });
        } else {
            // Force check if everything is empty
            var anyChecked = false;
            itemCheckboxes.forEach(function(chk) {
                if (chk.checked) anyChecked = true;
            });
            if (!anyChecked) chkAll.checked = true;
        }
        updateBrandSelection(userId);
    }

    function onBrandItemChanged(userId) {
        var chkAll = document.getElementById("chkAll_" + userId);
        var itemCheckboxes = document.querySelectorAll(".brand-chk-" + userId);
        
        var anyChecked = false;
        itemCheckboxes.forEach(function(chk) {
            if (chk.checked) anyChecked = true;
        });
        
        if (anyChecked) {
            chkAll.checked = false;
        } else {
            chkAll.checked = true;
        }
        updateBrandSelection(userId);
    }

    function updateBrandSelection(userId) {
        var chkAll = document.getElementById("chkAll_" + userId);
        var itemCheckboxes = document.querySelectorAll(".brand-chk-" + userId);
        var hiddenInput = document.getElementById("restrictedBrand_" + userId);
        var button = document.getElementById("brandBtn_" + userId);
        
        if (chkAll.checked) {
            hiddenInput.value = "ALL";
            button.innerText = "ALL Products";
        } else {
            var selected = [];
            var totalCount = 0;
            itemCheckboxes.forEach(function(chk) {
                if (chk.checked) {
                    selected.push(chk.value);
                    totalCount += parseInt(chk.getAttribute("data-count") || 0);
                }
            });
            
            if (selected.length === 0) {
                chkAll.checked = true;
                hiddenInput.value = "ALL";
                button.innerText = "ALL Products";
            } else {
                hiddenInput.value = selected.join(",");
                if (selected.length === 1) {
                    button.innerText = selected[0] + " (" + totalCount + " Items)";
                } else {
                    button.innerText = selected.length + " Brands (" + totalCount + " Items)";
                }
            }
        }
    }
</script>