@model IEnumerable<Dictionary<string, object>>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="container-fluid mt-1 saas-grid-gap">
    <!-- Top Action Bar -->
    <div class="saas-card mb-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title mb-1"><i class="fa-solid fa-clock-history text-primary me-2"></i>System Audit Logs</h1>
            <p class="text-secondary m-0" style="font-size: 0.9rem;">
                @if (!string.IsNullOrEmpty(ViewBag.SelectedFilterUser)) {
                    <span>Showing activity logs for user: <strong>@ViewBag.SelectedFilterUser</strong></span>
                } else {
                    <span>View all system operations and user activity logs in real-time.</span>
                }
            </p>
        </div>
        <div class="d-flex gap-2">
            @if (!string.IsNullOrEmpty(ViewBag.SelectedFilterUser)) {
                <a asp-action="History" class="btn btn-saas-secondary"><i class="fa-solid fa-filter-circle-xmark me-1"></i> Clear Filters</a>
            }
            <a asp-action="Users" class="btn btn-saas-secondary"><i class="fa-solid fa-users-gear me-1"></i> Manage Users</a>
            <a asp-action="Index" class="btn btn-saas-primary">Dashboard</a>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="saas-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="saas-table mb-0 text-center">
                <thead>
                    <tr>
                        <th style="width: 100px; text-align: center;">Log ID</th>
                        <th style="width: 180px; text-align: center;">User</th>
                        <th style="width: 180px; text-align: center;">Action</th>
                        <th class="text-start">Description</th>
                        <th style="width: 220px; text-align: center;">Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any()) {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-triangle-exclamation text-warning fs-3 mb-2 d-block"></i>
                                <span>No activity logs found matching the current filters.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        string badgeStyle = "background-color: #E2E8F0; color: #475569;";
                        string logAction = log["Action"]?.ToString() ?? "LOG";
                        if (logAction == "LOGIN") badgeStyle = "background-color: #E8F5E9; color: #16A34A;";
                        else if (logAction == "ADD_ROW") badgeStyle = "background-color: #E8F5E9; color: #16A34A;";
                        else if (logAction == "EDIT") badgeStyle = "background-color: #FFF3E0; color: #D97706;";
                        else if (logAction == "DELETE") badgeStyle = "background-color: #FEF2F2; color: #DC2626;";
                        else if (logAction == "PERMISSIONS") badgeStyle = "background-color: #FDF2F8; color: #BE185D;";
                        else if (logAction.Contains("PASSWORD")) badgeStyle = "background-color: #F1F5F9; color: #0F172A;";

                        <tr>
                            <td class="text-secondary fw-bold">#@log["Id"]</td>
                            <td class="fw-bold text-dark text-uppercase">👤 @log["User"]</td>
                            <td>
                                <span class="brand-badge" style="@badgeStyle font-size: 0.72rem; width: 130px; justify-content: center;">@logAction</span>
                            </td>
                            <td class="text-start text-dark fw-medium px-3" style="font-size:0.85rem;">@log["Desc"]</td>
                            <td class="text-secondary font-monospace fw-medium">
                                <i class="fa-regular fa-clock text-muted me-1"></i> @log["Time"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>