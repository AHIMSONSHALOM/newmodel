@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in - Google Accounts</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --google-blue: #1a73e8;
            --google-blue-hover: #1557b0;
            --text-dark: #202124;
            --text-muted: #5f6368;
            --border-color: #dadce0;
            --bg-color: #ffffff;
        }

        body {
            background-color: #f0f4f9;
            font-family: 'Roboto', sans-serif;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            color: var(--text-dark);
        }

        .auth-container {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
            width: 100%;
            max-width: 450px;
            padding: 40px;
            box-sizing: border-box;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .google-logo {
            display: flex;
            justify-content: center;
            margin-bottom: 16px;
        }

        .google-logo svg {
            width: 75px;
            height: 24px;
        }

        .header-title {
            font-size: 24px;
            font-weight: 400;
            text-align: center;
            margin: 0 0 8px 0;
            color: var(--text-dark);
        }

        .header-subtitle {
            font-size: 16px;
            text-align: center;
            margin: 0 0 24px 0;
            color: var(--text-muted);
        }

        .account-list {
            margin-bottom: 24px;
            border-top: 1px solid var(--border-color);
        }

        .account-item {
            display: flex;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
            cursor: pointer;
            transition: background-color 0.15s ease;
        }

        .account-item:hover {
            background-color: #f8f9fa;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background-color: #15cda8;
            color: #ffffff;
            font-weight: 500;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            text-transform: uppercase;
        }

        .avatar.blue {
            background-color: var(--google-blue);
        }

        .avatar-another {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            background-color: transparent;
            color: var(--text-muted);
        }

        .account-details {
            flex-grow: 1;
        }

        .account-name {
            font-size: 14px;
            font-weight: 500;
            margin: 0;
        }

        .account-email {
            font-size: 12px;
            color: var(--text-muted);
            margin: 0;
        }

        .footer-notice {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.5;
            margin-top: 28px;
        }

        /* sliding panels */
        .panel {
            transition: opacity 0.2s ease;
        }

        .panel-hidden {
            display: none !important;
            opacity: 0;
        }

        /* custom login view */
        .form-group {
            margin-bottom: 20px;
            position: relative;
        }

        .form-input {
            width: 100%;
            padding: 14px 12px;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-size: 16px;
            box-sizing: border-box;
            outline: none;
            transition: border-color 0.15s ease;
        }

        .form-input:focus {
            border-color: var(--google-blue);
            box-shadow: inset 0 0 0 1px var(--google-blue);
        }

        .form-label {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: var(--bg-color);
            padding: 0 4px;
            color: var(--text-muted);
            transition: 0.15s ease;
            pointer-events: none;
            font-size: 16px;
        }

        .form-input:focus ~ .form-label,
        .form-input:not(:placeholder-shown) ~ .form-label {
            top: 0;
            font-size: 12px;
            color: var(--google-blue);
        }

        .btn-group {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 32px;
        }

        .btn-link {
            color: var(--google-blue);
            background: none;
            border: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            padding: 0;
            text-decoration: none;
            transition: color 0.15s ease;
        }

        .btn-link:hover {
            color: var(--google-blue-hover);
        }

        .btn-submit {
            background-color: var(--google-blue);
            color: #ffffff;
            border: none;
            border-radius: 4px;
            padding: 10px 24px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
            transition: background-color 0.15s ease;
        }

        .btn-submit:hover {
            background-color: var(--google-blue-hover);
        }

        .alert-error {
            background-color: #fde8e8;
            border: 1px solid #f8b4b4;
            color: #9b1c1c;
            padding: 10px 12px;
            border-radius: 4px;
            font-size: 13px;
            margin-bottom: 20px;
            display: none;
            align-items: center;
            gap: 8px;
        }

        .alert-demo-info {
            background-color: #eef2ff;
            border: 1px solid #c7d2fe;
            color: #3730a3;
            padding: 12px;
            border-radius: 6px;
            font-size: 13px;
            margin-bottom: 20px;
            display: none;
            flex-direction: column;
            gap: 4px;
        }

        .spinner {
            border: 2px solid rgba(26, 115, 232, 0.2);
            border-top: 2px solid var(--google-blue);
            border-radius: 50%;
            width: 16px;
            height: 16px;
            animation: spin 0.8s linear infinite;
            display: inline-block;
            vertical-align: middle;
            margin-right: 8px;
        }

        .device-prompt-icon {
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
        }

        .device-prompt-icon svg {
            width: 64px;
            height: 64px;
            color: var(--google-blue);
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>

    <div class="auth-container">
        <div class="google-logo">
            <svg viewBox="0 0 74 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.24 17.8c-1.3 0-2.5-.3-3.6-1-.9-.7-1.6-1.6-2.1-2.7S2.8 11.8 2.8 10c0-1.8.3-3.4.9-4.5.6-1.1 1.3-2 2.3-2.7 1-1 2.2-1.3 3.5-1.3 1.6 0 3 .5 4 1.5 1.1 1 1.6 2.4 1.6 4.3v1h-8.3c0 .9.3 1.7.9 2.3s1.3.9 2.2.9c.8 0 1.5-.2 2.1-.6s.9-.9 1.1-1.6l2.1.8c-.4 1.1-1.1 2-2.1 2.7-1.1.7-2.3 1.1-3.7 1.1zm2.3-9.5c0-.8-.3-1.4-.7-1.9s-1.1-.7-1.9-.7c-.7 0-1.3.2-1.7.7s-.7 1.1-.8 1.9h5.1zM28 17.8c-1.3 0-2.4-.3-3.4-1s-1.7-1.6-2.2-2.7-.8-2.3-.8-3.7.3-2.6.8-3.7 1.2-2 2.2-2.7c1-.7 2.1-1 3.4-1s2.4.3 3.4 1 1.7 1.6 2.2 2.7.8 2.3.8 3.7-.3 2.6-.8 3.7-1.2 2-2.2 2.7c-1 .7-2.1 1-3.4 1zm0-2.1c.8 0 1.5-.3 2-.9s.8-1.4.8-2.4-.3-1.8-.8-2.4-1.2-.9-2-.9-1.5.3-2 .9-.8 1.4-.8 2.4.3 1.8.8 2.4 1.2.9 2 .9zm14 2.1c-1.3 0-2.4-.3-3.4-1s-1.7-1.6-2.2-2.7-.8-2.3-.8-3.7.3-2.6.8-3.7 1.2-2 2.2-2.7c1-.7 2.1-1 3.4-1s2.4.3 3.4 1 1.7 1.6 2.2 2.7.8 2.3.8 3.7-.3 2.6-.8 3.7-1.2 2-2.2 2.7c-1 .7-2.1 1-3.4 1zm0-2.1c.8 0 1.5-.3 2-.9s.8-1.4.8-2.4-.3-1.8-.8-2.4-1.2-.9-2-.9-1.5.3-2 .9-.8 1.4-.8 2.4.3 1.8.8 2.4 1.2.9 2 .9zM55.24 22.4c-1.1 0-2.1-.2-3-.7s-1.5-1.1-1.9-2l2-1c.3.5.7.9 1.2 1.2s1.1.4 1.8.4c1 0 1.8-.3 2.3-.9s.7-1.5.7-2.7V15.5h-.1c-.4.5-.9 1-1.6 1.3-.7.3-1.5.5-2.3.5-1.2 0-2.3-.3-3.3-1s-1.7-1.6-2.2-2.7-.8-2.3-.8-3.7.3-2.6.8-3.7 1.2-2 2.2-2.7 2.1-1 3.3-1c.8 0 1.6.2 2.3.5.7.3 1.2.8 1.6 1.3h.1V1.8h2.3v13.5c0 1.8-.5 3.3-1.4 4.4-.9 1.1-2.2 1.7-4 1.7zm.1-8c.8 0 1.4-.3 1.9-.9s.7-1.4.7-2.4-.2-1.8-.7-2.4-1.1-.9-1.9-.9-1.4.3-1.9.9-.7 1.4-.7 2.4.2 1.8.7 2.4 1.1.9 1.9.9zM65.8 17.5h-2.3V0h2.3v17.5zm7 0h-2.3V0h2.3v17.5z" fill="#5F6368"/>
                <path d="M9.24 9c-.1 0-.2 0-.3-.1L.94 2.8C2.56 1 4.8 0 7.4 0c2.3 0 4.3.7 5.9 2 1.6 1.3 2.7 3.1 3.2 5.2l-2.4.7c-.4-1.4-1.1-2.5-2.2-3.3-1.1-.8-2.5-1.2-4.1-1.2-1.9 0-3.5.6-4.7 1.8S1.24 8.2 1.24 10.3" fill="#4285F4"/>
            </svg>
        </div>

        <!-- ERROR MESSAGE ALERT -->
        <div id="error-alert" class="alert-error">
            <span style="font-weight: bold;">⚠️</span>
            <span id="error-message">Error signing in. Please try again.</span>
        </div>

        <!-- DEMO INFO NOTICE -->
        <div id="demo-notice" class="alert-demo-info">
            <span style="font-weight: 700; font-size: 14px;">🛠️ Offline Demo Fallback OTP</span>
            <span style="font-size: 13px; font-weight: 500; margin-top: 2px;">
                Gmail SMTP dispatch skipped or failed. Use this verification code:
                <strong id="demo-otp-code" style="font-size: 15px; color: var(--google-blue); text-decoration: underline; margin-left: 4px;">123456</strong>
            </span>
        </div>

        <!-- PANEL 1: ACCOUNT CHOOSER -->
        <div id="panel-chooser" class="panel">
            <h1 class="header-title">Choose an account</h1>
            <p class="header-subtitle">to continue to ProductHub</p>

            <div class="account-list">
                <!-- Pre-defined Google account -->
                <div class="account-item" onclick="triggerOtpRequest('ahimsonshalom2003@gmail.com', 'Ahim Shalom')">
                    <div class="avatar blue">A</div>
                    <div class="account-details">
                        <p class="account-name">Ahim Shalom</p>
                        <p class="account-email">ahimsonshalom2003@gmail.com</p>
                    </div>
                </div>

                <!-- Another pre-defined account option for testing -->
                <div class="account-item" onclick="triggerOtpRequest('demo.user@gmail.com', 'Demo User')">
                    <div class="avatar">D</div>
                    <div class="account-details">
                        <p class="account-name">Demo User</p>
                        <p class="account-email">demo.user@gmail.com</p>
                    </div>
                </div>

                <!-- Use Another Account Option -->
                <div class="account-item" onclick="showCustomPanel()">
                    <div class="avatar-another">
                        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                    </div>
                    <div class="account-details">
                        <p class="account-name" style="color: var(--google-blue);">Use another account</p>
                    </div>
                </div>
            </div>

            <p class="footer-notice">
                To continue, Google will share your name, email address, language preference, and profile picture with ProductHub Console.
            </p>
        </div>

        <!-- PANEL 2: CUSTOM ACCOUNT FORM -->
        <div id="panel-custom" class="panel panel-hidden">
            <h1 class="header-title">Sign in</h1>
            <p class="header-subtitle">with your Google Account</p>

            <form id="custom-auth-form" onsubmit="handleCustomSubmit(e => e.preventDefault())">
                <div class="form-group">
                    <input type="text" id="custom-name" class="form-input" placeholder=" " required autocomplete="off" />
                    <label class="form-label" for="custom-name">First and Last Name</label>
                </div>

                <div class="form-group">
                    <input type="email" id="custom-email" class="form-input" placeholder=" " required autocomplete="off" />
                    <label class="form-label" for="custom-email">Google Email Address</label>
                </div>

                <div class="btn-group">
                    <button type="button" class="btn-link" onclick="showChooserPanel()">Back to chooser</button>
                    <button type="button" id="submit-btn" class="btn-submit" onclick="handleCustomSubmit()">
                        <span id="btn-text">Next</span>
                    </button>
                </div>
            </form>
        </div>

        <!-- PANEL 3: 2-STEP VERIFICATION -->
        <div id="panel-verification" class="panel panel-hidden">
            <div class="device-prompt-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 6c1.4 0 2.5 1.1 2.5 2.5S13.4 12 12 12s-2.5-1.1-2.5-2.5S10.6 7 12 7zm0 13c-2.7 0-5.18-1.58-6.19-4 .03-.99 2.01-1.7 4.19-1.7.53 0 1.14.07 1.7.19.14.03.26.11.33.22.44.75.87.99 1.97.99s1.53-.24 1.97-.99c.07-.11.19-.19.33-.22.56-.12 1.17-.19 1.7-.19 2.18 0 4.16.71 4.19 1.7-1.01 2.42-3.49 4-6.19 4z"/>
                </svg>
            </div>
            <h1 class="header-title">2-Step Verification</h1>
            <p id="verification-subtitle" class="header-subtitle" style="margin-bottom: 24px;">
                To help protect your account, Google wants to make sure it's really you. A 6-digit code has been sent to your email.
            </p>

            <form id="otp-verify-form" onsubmit="handleOtpSubmit(event)">
                <div class="form-group" style="margin-bottom: 8px;">
                    <input type="text" id="verification-code" class="form-input" placeholder=" " required autocomplete="off" maxlength="6" pattern="\d{6}" style="text-align: center; letter-spacing: 6px; font-size: 20px; font-weight: 700;" />
                    <label class="form-label" for="verification-code" style="left: 50%; transform: translate(-50%, -50%);">Enter 6-digit code</label>
                </div>

                <div class="btn-group">
                    <button type="button" class="btn-link" onclick="showChooserPanel()">Cancel</button>
                    <button type="submit" id="verify-submit-btn" class="btn-submit">
                        <span id="verify-btn-text">Verify</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const ONE_TIME_TOKEN = "@ViewBag.GoogleLoginToken";
        let activeEmail = "";
        let activeName = "";

        function showCustomPanel() {
            document.getElementById('panel-chooser').classList.add('panel-hidden');
            document.getElementById('panel-verification').classList.add('panel-hidden');
            document.getElementById('panel-custom').classList.remove('panel-hidden');
            document.getElementById('error-alert').style.display = 'none';
            document.getElementById('demo-notice').style.display = 'none';
        }

        function showChooserPanel() {
            document.getElementById('panel-custom').classList.add('panel-hidden');
            document.getElementById('panel-verification').classList.add('panel-hidden');
            document.getElementById('panel-chooser').classList.remove('panel-hidden');
            document.getElementById('error-alert').style.display = 'none';
            document.getElementById('demo-notice').style.display = 'none';
        }

        function showVerificationPanel(email) {
            document.getElementById('panel-chooser').classList.add('panel-hidden');
            document.getElementById('panel-custom').classList.add('panel-hidden');
            document.getElementById('panel-verification').classList.remove('panel-hidden');
            document.getElementById('verification-subtitle').innerHTML = `To help protect your account, Google wants to make sure it's really you. We sent a 6-digit verification code to <strong style="color: var(--text-dark);">${email}</strong>.`;
            document.getElementById('error-alert').style.display = 'none';
        }

        function showError(msg) {
            const errDiv = document.getElementById('error-alert');
            const errSpan = document.getElementById('error-message');
            errSpan.innerText = msg;
            errDiv.style.display = 'flex';
        }

        function triggerOtpRequest(email, name) {
            activeEmail = email;
            activeName = name;
            
            document.body.style.cursor = 'wait';
            document.getElementById('error-alert').style.display = 'none';
            document.getElementById('demo-notice').style.display = 'none';
            
            fetch('/Account/GoogleSendOtp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    email: email,
                    name: name,
                    token: ONE_TIME_TOKEN
                })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Server returned an authentication error.');
                }
                return response.json();
            })
            .then(data => {
                document.body.style.cursor = 'default';
                if (data.success) {
                    showVerificationPanel(email);
                    if (data.isDemo) {
                        document.getElementById('demo-otp-code').innerText = data.demoOtp;
                        document.getElementById('demo-notice').style.display = 'flex';
                    }
                } else {
                    showError(data.message || 'Verification token failed or expired.');
                }
            })
            .catch(err => {
                document.body.style.cursor = 'default';
                showError('Network connection issue. Failed to connect to secure authenticating backend server.');
                console.error(err);
            });
        }

        function handleCustomSubmit() {
            const nameVal = document.getElementById('custom-name').value.trim();
            const emailVal = document.getElementById('custom-email').value.trim();
            const submitBtn = document.getElementById('submit-btn');
            const btnText = document.getElementById('btn-text');

            if (!nameVal || !emailVal) {
                showError('Please complete both name and email fields.');
                return;
            }

            // Enter loading state
            submitBtn.disabled = true;
            btnText.innerHTML = '<span class="spinner"></span>Next';

            triggerOtpRequest(emailVal, nameVal);
            
            // Restore button state in case of failure (after delay)
            setTimeout(() => {
                submitBtn.disabled = false;
                btnText.innerHTML = 'Next';
            }, 3000);
        }

        function handleOtpSubmit(e) {
            e.preventDefault();
            
            const otpCode = document.getElementById('verification-code').value.trim();
            const verifyBtn = document.getElementById('verify-submit-btn');
            const verifyText = document.getElementById('verify-btn-text');

            if (otpCode.length !== 6 || isNaN(otpCode)) {
                showError('Please enter a valid 6-digit numeric verification code.');
                return;
            }

            document.getElementById('error-alert').style.display = 'none';
            verifyBtn.disabled = true;
            verifyText.innerHTML = '<span class="spinner"></span>Verifying...';

            fetch('/Account/GoogleVerifyOtp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    code: otpCode
                })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Server returned verification error.');
                }
                return response.json();
            })
            .then(data => {
                verifyBtn.disabled = false;
                verifyText.innerHTML = 'Verify';
                
                if (data.success) {
                    if (window.opener) {
                        window.opener.postMessage('google-signin-success', '*');
                    }
                    window.close();
                } else {
                    showError(data.message || 'Incorrect verification code. Please try again.');
                }
            })
            .catch(err => {
                verifyBtn.disabled = false;
                verifyText.innerHTML = 'Verify';
                showError('Network error occurred during OTP verification.');
                console.error(err);
            });
        }
    </script>
</body>
</html>
