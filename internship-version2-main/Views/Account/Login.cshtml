@model ProductHub_MVC.Models.User
@{
    Layout = null; // Suppresses master layout headers to keep the login card clean and centered
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log in - ProductHub Gatekeeper</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .login-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-card {
            background: #fdfdfd;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.06);
            width: 100%;
            max-width: 400px;
            padding: 40px 35px;
        }
        .login-title {
            font-size: 2.4rem;
            font-weight: 500;
            color: #212529;
            margin-bottom: 25px;
        }
        .form-control-login {
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            padding: 12px 15px;
            font-size: 1rem;
            color: #334155;
            transition: all 0.2s ease-in-out;
        }
        .form-control-login:focus {
            border-color: #198754;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15);
            outline: 0;
        }
        /* Vibrant Green Button Theme Style Widget */
        .btn-green-login {
            background-color: #198754;
            border: none;
            border-radius: 4px;
            color: #ffffff;
            font-size: 1.15rem;
            font-weight: 700;
            padding: 12px;
            width: 100%;
            transition: background-color 0.2s ease;
        }
        .btn-green-login:hover {
            background-color: #146c43;
            color: #ffffff;
        }
        .login-link {
            color: #0d6efd;
            text-decoration: none;
            font-size: 0.95rem;
        }
        .login-link:hover {
            text-decoration: underline;
        }
        .text-muted-login {
            color: #475569;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card">
            
            <div class="text-center">
                <h1 class="login-title">Log in</h1>
            </div>
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success p-2 small border-0 mb-3 text-center fw-semibold">
                    @TempData["Success"]
                </div>
            }

            <!-- Validation Error Alert Display -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger p-2 small border-0 bg-light text-danger mb-3 text-center fw-semibold">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Login" method="post">
                <!-- Username Input Box -->
                <div class="mb-3">
                    <input type="text" asp-for="Username" class="form-control form-control-login" placeholder="Username" required autocomplete="off" />
                </div>

                <!-- Password Input Box -->
                <div class="mb-3">
                    <input type="password" asp-for="Password" class="form-control form-control-login" placeholder="Password" required />
                </div>

                <!-- Vibrant Green Submission Action Button Widget -->
                <div class="mb-4 mt-2">
                    <button type="submit" class="btn btn-green-login">Log in</button>
                </div>

                <!-- Bottom Auxiliary Form Links Frame -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check m-0">
                        <input type="checkbox" class="form-check-input" id="rememberMeCheck" style="cursor: pointer;" />
                        <label class="form-check-label text-muted-login" for="rememberMeCheck" style="cursor: pointer; user-select: none;">Remember me</label>
                    </div>
                    <div>
                        <a asp-action="ForgotPassword" class="login-link">Forgot Password?</a>
                    </div>
                </div>
            </form>
        </div>

        <!-- Footer Independent Action Anchor Link -->
        <div class="text-center mt-3">
            <a href="#" onclick="alert('Account creation pipeline requires Administrator deployment access credentials.')" class="login-link">Create an Account</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>