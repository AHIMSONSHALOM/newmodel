@model ProductHub_MVC.Models.User
@{
    Layout = null; // Disables main navbar frame links prior to successful login clearance
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - ProductHub Gatekeeper Console</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">

    <div class="card shadow border-0 p-4 rounded" style="width: 100%; max-width: 420px;">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-dark m-0">🔒 PRODUCTHUB CONSOLE</h3>
            <small class="text-muted text-uppercase fw-semibold" style="font-size:0.75rem;">Authorization Console Gatekeeper</small>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small fw-semibold"></div>

            <div class="mb-3">
                <label class="form-label fw-bold small text-secondary">Username Identity</label>
                <input asp-for="Username" class="form-control" placeholder="Enter username..." autocomplete="off" required />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small text-secondary">Password Security Key</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Enter security key..." required />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-dark w-100 fw-bold py-2 shadow-sm">Authorize & Login</button>
        </form>
    </div>

</body>
</html>