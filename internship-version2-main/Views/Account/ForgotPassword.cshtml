@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>Account Recovery Framework</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="card shadow border-0 p-4 rounded" style="width: 100%; max-width: 420px;">
        <div class="text-center mb-4">
            <h4 class="fw-bold text-dark m-0"><i class="fa-solid fa-shield-halved text-success me-2"></i>PASSWORD RECOVERY</h4>
            <small class="text-muted text-uppercase fw-semibold" style="font-size:0.7rem;">Real-time Dynamic OTP Registry System</small>
        </div>
        @if (TempData["Error"] != null) { <div class="alert alert-danger border-0 small py-2">@TempData["Error"]</div> }
        <form asp-action="SendOtpCode" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold small text-secondary">Registered Mobile Number</label>
                <input type="text" name="mobileNumber" class="form-control form-control-sm" placeholder="Enter your 10-digit number..." required />
            </div>
            <button type="submit" class="btn btn-success btn-sm w-100 fw-bold py-2 shadow-sm">Dispatch Verification OTP</button>
            <div class="text-center mt-3"><a asp-action="Login" class="text-decoration-none small fw-semibold text-secondary">⬅️ Back to Entry Login</a></div>
        </form>
    </div>
</body>
</html>